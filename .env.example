MENTIS_PORT=8080
JOB_WORKERS=10
RECIPE_CATEGORY_WORKERS=10

# Required: reverse proxy basic auth in front of MentisEterna.
PROXY_BASIC_AUTH_USERNAME=
PROXY_BASIC_AUTH_PASSWORD=

# Point this at your LocalAI instance if you want embeddings/title generation/OCR/STT.
# Example: http://host.docker.internal:8188
# On Linux, host.docker.internal is provided by compose.yaml via host-gateway.
LOCALAI_BASE_URL=
LOCALAI_EMBEDDING_MODEL=
LOCALAI_CHAT_MODEL=
LOCALAI_OCR_MODEL=
LOCALAI_STT_MODEL=

# Leave blank to disable media + backups.
MEDIA_S3_ENDPOINTS=
BACKUP_ENCRYPTION_KEY=
